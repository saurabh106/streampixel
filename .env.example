# Node environment
NODE_ENV=development

# Server configurations
PORT=5000
CORS_ORIGIN=http://localhost:3000

# Database Connection (Postgres)
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/streampixel?schema=public"

# JWT Secrets
JWT_ACCESS_SECRET=your_jwt_access_token_secret_which_should_be_long_and_secure
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_which_should_be_long_and_secure

# Token Expirations
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# NextJS Frontend configuration
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
