NODE_ENV=development
PORT=5000
CORS_ORIGIN=*
DATABASE_URL="postgresql://postgres:your_password_here@localhost:5434/streampixel?schema=public"
JWT_ACCESS_SECRET=your_jwt_access_token_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_token_secret_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Storage root for extracted project files (Linux default: /opt/streampixel/storage)
STORAGE_PATH=D:\mvp\streampixel\storage
